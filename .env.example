# ImageProcessor Environment Variables
# Copy this file to .env.local and fill in the values

# Development environment (auto-created by Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Add your environment variables here
# Example:
# NEXT_PUBLIC_MY_VAR=value

# Note: Variables prefixed with NEXT_PUBLIC_ are available in the browser
# Variables without the prefix are only available on the server
